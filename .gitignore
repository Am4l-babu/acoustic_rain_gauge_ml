.venv/
venv/
__pycache__/
*.pyc
.ipynb_checkpoints/
.DS_Store

# Ignore data and models content, but keep structure
data/raw/*
!data/raw/.gitkeep

data/processed/*
!data/processed/.gitkeep
!data/processed/feature_engineering_metadata.json

data/external/*
!data/external/.gitkeep

models/*
!models/.gitkeep

# Cloned external repos kept locally for reference/analysis only
external_repos/

# Auto-memory system (project-specific)
.claude/

# Data artifacts and logs
*.parquet
docs/**/*.txt
docs/train_*_log.txt

# PlatformIO build artifacts
firmware/**/.pio/

# Wi-Fi credentials for the deployed sensor node (copy from wifi_config.h.example)
firmware/**/include/wifi_config.h

# Research papers and reference materials (large PDFs/docx/zip archives),
# including anything nested under subfolders like "research papers/"
ARG_Research/**/*.pdf
ARG_Research/**/*.docx
ARG_Research/**/*.zip

# Internship administrative paperwork (diary, report, template, submission
# format) -- personal/private, not part of the ML project itself
Internship_Daily_Diary.docx
Internship_Report_*.docx
Internship_Daily_Diary.pdf
Internship_Report_*.pdf
